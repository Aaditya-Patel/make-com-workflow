# Make CLI auth
MAKE_API_KEY=your-make-api-token
MAKE_ZONE=us2.make.com

# Azure OpenAI (synced to Pipeline1 / x-api-key on npm run push)
OPENAI_API_KEY=your-azure-openai-api-key
AZURE_OPENAI_ENDPOINT=https://make-com.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=your-deployment-name
AZURE_OPENAI_API_VERSION=2024-10-21

# Google Sheets (optional overrides for apply-google-sheet-config.mjs)
# GOOGLE_SPREADSHEET_NAME=Integration RSS - Trend Brief
# GOOGLE_SPREADSHEET_ID=your-spreadsheet-id-from-url
# GOOGLE_SHEET_TAB=Sheet1
# GOOGLE_CONNECTION_ID=9717356
